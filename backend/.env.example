# ── Groq API (https://console.groq.com) ───────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Zoho OAuth2 ───────────────────────────────────────────────────────────────
# Create your app at: https://api-console.zoho.in (India) or https://api-console.zoho.com
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback

# For production (Railway/Render):
# ZOHO_REDIRECT_URI=https://your-backend.up.railway.app/auth/callback

# ── Database (optional — omit to run in demo / Zoho-only mode) ───────────────
# MySQL (existing):
DATABASE_URL=mysql+aiomysql://root:YOUR_PASSWORD@localhost:3306/dealiq
# PostgreSQL (recommended for new deployments):
# DATABASE_URL=postgresql+asyncpg://dealiq:dealiq@localhost:5432/dealiq
# Set USE_ALEMBIC=true to skip auto-migration and use Alembic instead:
# USE_ALEMBIC=false

# ── Redis (optional — omit to disable caching and background tasks) ───────────
REDIS_URL=redis://localhost:6379/0
# Cache TTLs (seconds) — override defaults:
CACHE_TTL_HEALTH_SCORES=300
CACHE_TTL_PIPELINE_METRICS=120
CACHE_TTL_AI_ANALYSIS=1800
CACHE_TTL_DEAL_DETAIL=180

# ── Microsoft / Outlook OAuth2 ────────────────────────────────────────────────
# Azure Portal → App Registrations → your app
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/ms-auth/callback
OUTLOOK_USER_EMAIL=you@yourorg.com

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# For production: set to your Lovable.dev app URL
# FRONTEND_URL=https://your-app.lovable.app

# ── Salesforce CRM (optional) ─────────────────────────────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8000/auth/salesforce/callback

# ── HubSpot CRM (optional) ────────────────────────────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/auth/hubspot/callback

# ── CRM token encryption key ──────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRM_TOKEN_ENCRYPTION_KEY=
