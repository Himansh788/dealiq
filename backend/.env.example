# ── Groq API (https://console.groq.com) ───────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Zoho OAuth2 ───────────────────────────────────────────────────────────────
# Create your app at: https://api-console.zoho.in (India) or https://api-console.zoho.com
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback

# For production (Railway/Render):
# ZOHO_REDIRECT_URI=https://your-backend.up.railway.app/auth/callback

# ── MySQL (optional — omit to run in demo / Zoho-only mode) ──────────────────
# No password:  mysql+aiomysql://root:@localhost:3306/dealiq
DATABASE_URL=mysql+aiomysql://root:YOUR_PASSWORD@localhost:3306/dealiq

# ── Microsoft / Outlook OAuth2 ────────────────────────────────────────────────
# Azure Portal → App Registrations → your app
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/ms-auth/callback
OUTLOOK_USER_EMAIL=you@yourorg.com

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# For production: set to your Lovable.dev app URL
# FRONTEND_URL=https://your-app.lovable.app
